rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins — full access for any signed-in user
    match /admins/{adminId} {
      allow read, write, delete: if request.auth != null;
    }

    // Products & gadgets — public read, signed-in write
    match /products/{id} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
    match /gadgets/{id} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    // Hero slides — public read, signed-in write
    match /hero/{id} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }

    // Orders — public create (checkout), signed-in read/update
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Carts — public read/write (guest carts)
    match /carts/{id} {
      allow read, write: if true;
    }
  }
}
